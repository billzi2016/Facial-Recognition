*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.nox/
build/
dist/
*.egg-info/


# ==============================================================================
# 虚拟环境 / 本地环境变量
# ==============================================================================
.venv/
venv/
env/
.env
.env.*
!.env.example


# ==============================================================================
# 通用缓存
# ==============================================================================
.cache/
cache/
caches/
tmp/
temp/


# ==============================================================================
# 数据集与本地原始资源
# ==============================================================================
data/raw/*
!data/raw/.gitkeep
!data/raw/celeba/
data/raw/celeba/*
!data/raw/celeba/.gitkeep
data/processed/*
!data/processed/.gitkeep
!data/processed/celeba_full/
!data/processed/celeba_full/.gitkeep
!data/processed/celeba_subset/
!data/processed/celeba_subset/.gitkeep
!data/processed/celeba_subset/debug/
!data/processed/celeba_subset/debug/.gitkeep
data/manifests/*
!data/manifests/.gitkeep
*.zip
*.tar
*.tar.gz
*.tgz
*.7z


